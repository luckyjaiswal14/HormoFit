# Database connection string (MongoDB)
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/hormofit?retryWrites=true&w=majority

# NextAuth configuration
# Generate a secret using: openssl rand -base64 32
# You can also run `npx auth secret` to generate it automatically
NEXTAUTH_SECRET=your_nextauth_secret_here

# The base URL of your application (required for NextAuth)
NEXTAUTH_URL=http://localhost:3000
